# AVIV CaaS API — credentials issued by partners@groupeseloger.com
AVIV_CLIENT_ID=your_client_id
AVIV_CLIENT_SECRET=your_client_secret
AVIV_AUDIENCE=https://api.aviv-group.com/sandbox/caas/v4
AVIV_TOKEN_URL=https://auth.api.aviv-group.com/oauth/token
AVIV_API_BASE_URL=https://api.aviv-group.com/sandbox/caas/v4

# User-Agent is mandatory; AVIV firewall blocks requests without it
AVIV_USER_AGENT=SelogerConnector/0.1.0 Python/3.11

# Identifier of YOUR software (per-tenant offerer info lives in tenants.json)
AVIV_SOURCE_SYSTEM=SelogerConnector
AVIV_SOURCE_SYSTEM_VERSION=0.1.0

# Odoo (defaults; per-tenant credentials override via tenants.json)
ODOO_BASE_URL=https://your-odoo-instance.com
ODOO_API_KEY=your_odoo_api_key
ODOO_DATABASE=your_database_name

# Webhook server
WEBHOOK_URL=https://your-deployed-app.example.com
PORT=8000
LOG_LEVEL=INFO
ENABLE_DEBUG_ENDPOINT=false
